# Copy this file to .env and fill in real values before running the app.
# Never commit the actual .env file to version control.

# PostgreSQL — asyncpg driver (postgresql+asyncpg://...)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/oms_db

# JWT — generate a strong secret with: openssl rand -hex 32
JWT_SECRET_KEY=change_me_to_a_very_long_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Admin seed — used by python -m app.scripts.seed_admin
ADMIN_EMAIL=admin@oms.local
ADMIN_PASSWORD=Admin@1234
ADMIN_FULL_NAME=System Administrator
